    "eslint": "^8.53.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "next-image-export-optimizer": "^1.17.2",
    "prettier": "^3.1.0",
    "sharp": "^0.33.0",
    "terser": "^5.49.0",
    "vite": "^5.0.8",
    "vite-plugin-compression": "^0.5.1"
